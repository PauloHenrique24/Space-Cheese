--- !u!114 &637636691
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 637636690}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e8490306e248adf4787fa204d01faede, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogoText: {fileID: 237156242}
  personagemImage: {fileID: 2044380352}
  pular: {fileID: 39495177}
  delayNormal: 0.06
  delaySpeed: 0.03
  transition: {fileID: 11400000, guid: 057babd6f13132c449650d99e3c4e99c, type: 2}
  frases:
  - textoFrase: "\u201CDon Cheddaro! Eu... eu prometo que pago! S\xF3 preciso de
      mais um ciclo solar!\u201D, implorou Zezin, ofegante."
    personagemImage: {fileID: -2576023137440582333, guid: 1efaefd11414dc84eb7253e0ac3c0c7b, type: 3}
  - textoFrase: "\u201CVoc\xEA est\xE1 atrasado, Zezin. Muito atrasado\u201D, d\xEDvidas
      se pagam com queijo. Ou com a vida.\u201D"
    personagemImage: {fileID: -6833466743104742095, guid: b1a139d6240c6e04f9636e245ec1d6f7, type: 3}
  - textoFrase: "\u201CMas eu estou quebrado! Todo o meu estoque de Parmesonium virou
      fuma\xE7a depois daquela corrida pelos an\xE9is de Saturno!\u201D"
    personagemImage: {fileID: -2576023137440582333, guid: 1efaefd11414dc84eb7253e0ac3c0c7b, type: 3}
  - textoFrase: "\u201CEnt\xE3o recorra \xE0 fonte mais pura do universo: leite das
      vacas da Terra. S\xF3 com ele voc\xEA pode produzir o queijo que me deve.\u201D"
    personagemImage: {fileID: -6833466743104742095, guid: b1a139d6240c6e04f9636e245ec1d6f7, type: 3}
  - textoFrase: "\"A Terra...? Mas os humanos guardam essas vacas como rel\xEDquias
      sagradas de quatro est\xF4magos!\"\r\n"
    personagemImage: {fileID: -2576023137440582333, guid: 1efaefd11414dc84eb7253e0ac3c0c7b, type: 3}
  - textoFrase: "\"Exatamente. Voc\xEA tem sete dias. Quatro abdu\xE7\xF5es por dia.
      Se perder, a oportunidade estar\xE1 perdida. Seja inteligente. Seja furtivo.
      Traga o leite... ou prepare-se para derreter na frigideira do destino.\"\r"
    personagemImage: {fileID: -6833466743104742095, guid: b1a139d6240c6e04f9636e245ec1d6f7, type: 3}
